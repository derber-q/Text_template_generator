"""Запуск desktop-приложения без консольного окна в Windows."""

# Импортируется основная функция запуска, чтобы `main.pyw` был тонкой оберткой над обычной точкой входа.
from main import main


if __name__ == "__main__":
    # При запуске через pythonw.exe или двойным кликом Windows не показывает консольное окно.
    main()
